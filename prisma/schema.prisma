generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model OnboardingSession {
  id            String    @id @default(uuid())
  token         String    @unique
  status        Status    @default(PENDING)

  // HR-filled fields
  name          String    @db.VarChar(50)
  department    String    @db.VarChar(100)
  division      String    @db.VarChar(100)
  title         String    @db.VarChar(100)
  startDate     DateTime  @db.Date
  contactEmail  String    @db.VarChar(255)

  // Employee-filled fields (null until submitted)
  taiccaEmail   String?   @db.VarChar(255)
  englishFirst  String?   @db.VarChar(50)
  englishLast   String?   @db.VarChar(50)
  englishName   String?   @db.VarChar(100)
  showPhone     Boolean?
  phoneNumber   String?   @db.VarChar(30)
  photoPath     String?   @db.VarChar(500)

  // HR confirmation
  employeeId    String?   @db.VarChar(20)
  ragicSyncedAt DateTime?

  ragicCache    Json?

  // Timestamps
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  submittedAt   DateTime?
  confirmedAt   DateTime?

  employeeForm  EmployeeFormData?

  @@index([status])
  @@index([taiccaEmail])
  @@index([englishName])
}

// 員工基本資料 + 薪資扣繳選擇表 電子表單資料
model EmployeeFormData {
  id                String    @id @default(uuid())
  sessionId         String    @unique
  session           OnboardingSession @relation(fields: [sessionId], references: [id])

  // ── 基本資料 ──
  birthDate         String?             // 民國年格式 "113/01/01"
  idNumber          String?   @db.VarChar(20)
  birthplace        String?   @db.VarChar(50)
  nationality       String?   @db.VarChar(30)
  bloodType         String?   @db.VarChar(5)
  gender            String?   @db.VarChar(5)
  maritalStatus     String?   @db.VarChar(10)
  childrenCount     String?   @db.VarChar(10)   // 舊欄位，保留相容性
  sonsCount         String?   @db.VarChar(10)   // 兒子數
  daughtersCount    String?   @db.VarChar(10)   // 女兒數
  homePhone         String?   @db.VarChar(30)
  mobilePhone       String?   @db.VarChar(30)
  personalEmail     String?   @db.VarChar(255)
  permanentAddress  String?   @db.VarChar(200)
  currentAddress    String?   @db.VarChar(200)
  sameAddress       Boolean   @default(false)

  // ── 動態陣列欄位（JSON）──
  education         Json?   // [{from,to,school,dept,dayNight,years,graduated,note}]
  workHistory       Json?   // [{from,to,company,position,salary,reason}]
  languageSkills    Json?   // [{lang,listen,speak,read,write}] 1-5分
  familyMembers     Json?   // [{relation,name,birthDate,occupation,address}]
  nhiDependents     Json?   // [{name,idNumber,birthDate,relation}] 最多3人

  // ── 緊急聯絡人 ──
  emergencyName     String?   @db.VarChar(50)
  emergencyRelation String?   @db.VarChar(20)
  emergencyPhone    String?   @db.VarChar(30)

  // ── 勞工退休金 ──
  laborPensionSelf  Boolean?
  laborPensionRate  String?   @db.VarChar(5)

  // ── 扣繳選擇 ──
  withholdingMethod String?   @db.VarChar(5)  // "1" | "2"

  // ── 免稅人口（JSON）──
  taxDependents     Json?   // [{type,name,relation,birthDate,idNumber,address,condition}]

  // ── 個資同意 ──
  consentAgreed     Boolean   @default(false)

  submittedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model DepartmentCache {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  divisions Json
  updatedAt DateTime @updatedAt
}

model SystemConfig {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

enum Status {
  PENDING
  SUBMITTED
  CONFIRMED
}
